DATABASE_URL=postgres://twintracker:twintracker@localhost:5432/twintracker
JWT_SECRET=change-me-min-32-chars-in-production
PORT=3000
APP_URL=http://localhost:3001

# Email verification
# Leave blank in local dev — verification links are logged to the API console instead.
# Set all five in production to send real emails via SMTP (recommended: Resend).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@twintracker.app

# Web app
API_URL=http://localhost:3000
WEB_PORT=3001
